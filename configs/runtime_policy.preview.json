{
  "schema_version": 1,
  "fair_value": {
    "field": "raw"
  },
  "strategy": {
    "base_quantity": 1.0,
    "edge_threshold": 0.03
  },
  "risk_limits": {
    "max_global_contracts": 20,
    "max_contracts_per_market": 5,
    "max_contracts_per_event": 10,
    "min_price": 0.01,
    "max_price": 0.99,
    "enforce_atomic_batches": true
  },
  "execution_policy_gate": {
    "min_top_level_liquidity": 0.0,
    "cooldown_seconds": 0.0,
    "block_on_unhealthy_reconciliation": true,
    "prevent_same_side_duplicate": true,
    "block_on_contract_partial_fills": true
  }
}
