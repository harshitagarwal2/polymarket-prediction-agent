    }
  },
  "pair_opportunity_ranker": {
    "freeze_windows": {
      "freeze_minutes_before_start": 10,
      "freeze_minutes_before_expiry": 0,
      "freeze_when_inactive": true,
      "freeze_when_resolved": true
    }
