# Core Postgres authority
POSTGRES_DB=prediction_market
POSTGRES_USER=prediction_market
POSTGRES_PASSWORD=prediction_market
PREDICTION_MARKET_POSTGRES_DSN=postgresql://prediction_market:prediction_market@postgres:5432/prediction_market
PREDICTION_MARKET_POSTGRES_TEST_DSN=postgresql://prediction_market:prediction_market@postgres:5432/prediction_market
PREDICTION_MARKET_HTTP_MIN_INTERVAL_SECONDS=

# Sportsbook capture
THE_ODDS_API_KEY=replace-me
SPORTSGAMEODDS_API_KEY=replace-me
SPORTSBOOK_CAPTURE_PROVIDER=theoddsapi
SPORTSBOOK_PROVIDER_URL=
SPORT_KEY=basketball_nba
SPORTSBOOK_MARKET=h2h

# Polymarket capture / runtime
POLYMARKET_PRIVATE_KEY=replace-me
POLYMARKET_PRIVATE_KEY_COMMAND=
POLYMARKET_PRIVATE_KEY_FILE=
POLYMARKET_FUNDER=replace-me
POLYMARKET_ACCOUNT_ADDRESS=replace-me
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_DATA_API_HOST=https://data-api.polymarket.com
POLYMARKET_ROUTE_LABEL=
POLYMARKET_GEO_COMPLIANCE_ACK=false
POLYMARKET_PRIVATE_ORDER_FLOW_REQUIRED=false
POLYMARKET_USER_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/user
POLYMARKET_ASSET_ID=replace-me
POLYMARKET_LIVE_USER_MARKETS=replace-me

# Runtime staging / supervised defaults
RUNTIME_POLICY_FILE=configs/runtime_policy.staging.json
RUNTIME_FAIR_VALUES_FILE=runtime/data/current/fair_value_manifest.json
